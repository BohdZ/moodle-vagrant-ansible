- name: Install Apache + PHP
  apt:
    name:
      - apache2
      - php
      - libapache2-mod-php
      - php-mysql
      - php-xml
      - php-gd
      - php-curl
      - php-intl
      - php-zip
      - php-mbstring
    state: present

- name: Enable rewrite
  apache2_module:
    name: rewrite
    state: present

- name: Restart Apache
  service:
    name: apache2
    state: restarted
